<!DOCTYPE html>
<html>
<head>
  <title>Pizza AR</title>

  <script type="module"
    src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js">
  </script>

  <style>
    body{
      margin:0;
      background:#f5f5f5;
    }

    model-viewer{
      width:100%;
      height:100vh;
    }
  </style>
</head>

<body>

<model-viewer
  src="pizza (3).glb"
  ar
  ar-modes="scene-viewer webxr quick-look"
  camera-controls
  auto-rotate
  shadow-intensity="1">
</model-viewer>

</body>
</html>